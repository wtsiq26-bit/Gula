// ──────────────────────────────────────────────────────────────
// Gula PMS — Prisma Schema (Multi-Tenant Architecture)
// Complete database schema for all modules:
//   Pharmacy, User, Supplier, Medicine, Batch, Sale, SaleItem
// ──────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Pharmacy ────────────────────────────────────────────────
// Top-level tenant model. All operational data is isolated per pharmacy.
// ─────────────────────────────────────────────────────────────
model Pharmacy {
  id        String   @id @default(uuid())
  name      String
  location  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users      User[]
  suppliers  Supplier[]
  medicines  Medicine[]
  batches    Batch[]
  sales      Sale[]
  saleItems  SaleItem[]
}

// ─── User ────────────────────────────────────────────────────
// Pharmacy staff user accounts. Belongs to a single Pharmacy tenant.
// ─────────────────────────────────────────────────────────────
model User {
  id         String   @id @default(uuid())
  username   String
  email      String   @unique
  password   String   // bcrypt-hashed
  role       String   @default("ADMIN") // ADMIN | PHARMACIST
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  pharmacyId String
  pharmacy   Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  sales      Sale[]

  @@index([pharmacyId])
  @@index([email])
}

// ─── Supplier ────────────────────────────────────────────────
// Companies supplying medicines to a specific pharmacy tenant.
// ─────────────────────────────────────────────────────────────
model Supplier {
  id            String   @id @default(uuid())
  name          String
  contactPerson String?
  phone         String?
  email         String?
  address       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  pharmacyId String
  pharmacy   Pharmacy   @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  medicines  Medicine[]

  @@index([pharmacyId])
}

// ─── Medicine ────────────────────────────────────────────────
// Inventory items isolated per tenant or flagged as global catalog entries.
// ─────────────────────────────────────────────────────────────
model Medicine {
  id             String    @id @default(uuid())
  tradeName      String
  genericName    String?
  scientificName String?
  category       String?
  barcode        String?
  manufacturer   String?
  country        String?
  dosageForm     String?
  nationalCode   String?
  costPrice      Float     @default(0)
  sellingPrice   Float     @default(0)
  stock          Int       @default(0)
  totalStock     Int       @default(0)
  expiryDate     DateTime?
  image          String?   // File path to uploaded image
  isGlobal       Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  pharmacyId String
  pharmacy   Pharmacy   @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  supplierId String?
  supplier   Supplier?  @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  saleItems  SaleItem[]
  batches    Batch[]

  @@unique([pharmacyId, barcode])
  @@index([pharmacyId])
  @@index([barcode])
  @@index([supplierId])
}

// ─── Batch ───────────────────────────────────────────────────
// Medical-grade FEFO batch tracking isolated per tenant.
// ─────────────────────────────────────────────────────────────
model Batch {
  id          String    @id @default(uuid())
  medicineId  String
  medicine    Medicine  @relation(fields: [medicineId], references: [id], onDelete: Cascade)
  pharmacyId  String?
  pharmacy    Pharmacy? @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  quantity    Int       @default(0)
  expiryDate  DateTime
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([pharmacyId])
  @@index([medicineId])
  @@index([expiryDate])
}

// ─── Sale ────────────────────────────────────────────────────
// Checkout sales transactions per pharmacy tenant.
// ─────────────────────────────────────────────────────────────
model Sale {
  id            String   @id @default(uuid())
  invoiceNumber String   @unique @default(uuid())
  totalAmount   Float
  paymentMethod String   @default("CASH") // CASH | CARD | MOBILE
  createdAt     DateTime @default(now())

  // Relations
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pharmacyId String
  pharmacy   Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  items      SaleItem[]

  @@index([pharmacyId])
  @@index([userId])
  @@index([createdAt])
}

// ─── SaleItem ────────────────────────────────────────────────
// Individual line items in sales transactions.
// ─────────────────────────────────────────────────────────────
model SaleItem {
  id        String @id @default(uuid())
  quantity  Int
  unitPrice Float

  // Relations
  saleId     String
  sale       Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)
  medicineId String
  medicine   Medicine  @relation(fields: [medicineId], references: [id], onDelete: Cascade)
  pharmacyId String?
  pharmacy   Pharmacy? @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)

  @@index([pharmacyId])
  @@index([saleId])
  @@index([medicineId])
}
